{
  "name": "voice-to-txt-02",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "build:cloudflare": "npx @opennextjs/cloudflare build && cp wrangler.tomlc .open-next/wrangler.tomlc",
    "verify:build": "ls -la .open-next && [ -f .open-next/worker.js ] && [ -f .open-next/wrangler.tomlc ]",
    "deploy": "npm run build:cloudflare && npm run verify:build && npx @opennextjs/cloudflare deploy",
    "deploy:staging": "npm run build:cloudflare && npm run verify:build && npx @opennextjs/cloudflare deploy --env staging",
    "cf:dev": "wrangler dev",
    "cf:logs": "wrangler tail",
    "cf:secret:list": "wrangler secret list",
    "cf:secret:put": "wrangler secret put"
  },
  "dependencies": {
    "@paypal/react-paypal-js": "^9.0.2",
    "@radix-ui/react-slot": "^1.2.4",
    "@sentry/browser": "^10.46.0",
    "@sentry/cloudflare": "^10.45.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.0.1",
    "next": "^15.5.10",
    "openai": "^6.33.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.71.2",
    "react-turnstile": "^1.1.5",
    "tailwind-merge": "^3.5.0",

    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "@opennextjs/cloudflare": "^1.18.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.27.4",
    "eslint": "^9",
    "eslint-config-next": "15.5.9",
    "eslint-config-prettier": "^10.1.8",
    "miniflare": "^4.20260317.3",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
